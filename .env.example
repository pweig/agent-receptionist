# Required
GROQ_API_KEY=gsk_...

# Optional: which after-hours emergency number and message to use ("de" or "us").
# This does NOT control the agent's conversational language — that is auto-detected
# from the caller's speech by Whisper and handled by the set_language tool.
OFFICE_LOCALE=de

# Optional: override Whisper model (overrides settings.yaml).
# tiny   ~75MB   fast, lower quality — good for flow testing
# small  ~460MB  good EN+DE quality — default for POC
# medium ~1.5GB  better quality
# large-v3-turbo ~800MB  near-production quality
WHISPER_MODEL=small

# Optional: port for the local WebRTC server (default: 7860)
# PORT=7860

# PII logging — set to true only for debugging in a private dev environment.
# When false (default), raw STT transcriptions are redacted before printing or
# writing to events.jsonl (dates and phone numbers replaced with [DOB]/[PHONE]).
LOG_PII=false

# Call audio capture — writes raw 8 kHz SLIN PCM to logs/captures/session_<id>.raw.
# Use only during VAD/STT tuning; never in production (contains PII audio).
# Convert to WAV for playback: make convert-captures
CAPTURE_CALLS=false

# When true (default), incoming calls outside office_hours.yaml are blocked at
# the entry gate — the caller hears the prepared after-hours announcement and
# the call ends without engaging the LLM. Set to false in dev to test the
# full flow regardless of the wall clock.
ENFORCE_OFFICE_HOURS=true
