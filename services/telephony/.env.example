# FritzBox SIP registration credentials
# Copy to .env and fill in values from the FritzBox IP-phone config.

# FritzBox LAN IP (default on most setups)
FRITZBOX_HOST=192.168.178.1

# Credentials of the internal IP phone you create in:
# fritz.box → Telefonie → Telefoniegeräte → Neues Gerät einrichten → Telefon (IP-Telefon)
FRITZBOX_USER=receptionist
FRITZBOX_PASS=<Fill in your passwd>

# The LAN IP of the host running this Docker container.
# Asterisk advertises this as its contact address so FritzBox can reach it.
# Check with `ipconfig getifaddr en0` on macOS.
EXTERNAL_IP=192.168.178.197
